<?php
declare(strict_types=1);

use MageObsidian\ModernFrontend\Block\Template;

/**
 * @var Template $block
 */
?>

<div id="search-panel" class="relative">
    <div v-cloak v-show="mainStore.searchOpen" ref="root" class="absolute w-full bg-gray-50 shadow-md p-4">
        <div class="container mx-auto w-full">
            <input
                    ref="searchInput"
                    type="text"
                    placeholder="Search"
                    class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"
            >
        </div>
    </div>
</div>

<script type="module">
    import {createApp, ref, watch, nextTick} from 'vue';
    import {pinia, useMainStore} from 'mainStore';
    import {onClickOutside} from 'mini-vueuse'

    const app = createApp({
        setup() {
            const mainStore = useMainStore();
            const searchInput = ref(null);
            const root = ref(null);
            watch(
                () => mainStore.searchOpen,
                (newValue) => {
                    if (newValue) {
                        nextTick(() => {
                            if (searchInput.value) {
                                searchInput.value.focus();
                            }
                        });
                    }
                }
            );

            onClickOutside(root, (event) => {
                if (mainStore.searchOpen) {
                    const insideRoot = root.value && root.value.contains(event.target);
                    const insideSearchlink = mainStore.searchLink && mainStore.searchLink.contains(event.target);
                    if (!insideRoot && !insideSearchlink
                    ) {
                        mainStore.searchOpen = false;
                    }
                }
            });

            return {
                mainStore,
                searchInput,
                root
            };
        },
    });

    app.use(pinia);

    app.mount('#search-panel');
</script>
