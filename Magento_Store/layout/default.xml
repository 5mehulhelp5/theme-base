<?xml version="1.0"?>
<page layout="3columns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock
                name="header.panel.block"
        >
            <block class="Magento\Store\Block\Switcher" name="store_language" as="store_language"
                   template="Magento_Store::switch/languages.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        Magento\Store\ViewModel\SwitcherUrlProvider
                    </argument>
                    <argument name="vite_resolver" xsi:type="object">
                        MageObsidian\ModernFrontend\ViewModel\ViteResolver
                    </argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
